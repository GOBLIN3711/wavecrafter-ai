generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  venueType String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Track {
  id         String   @id @default(cuid())
  title      String
  titleRu    String
  description String?
  genre      String?
  duration   Float?
  fileName   String?
  audioUrl   String?
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
